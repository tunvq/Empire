# ============================================================
# JIRA & XRAY INTEGRATION - Environment Variables
# ============================================================
# Copy file này thành .env và điền giá trị thực tế
#   cp .env.example .env
#
# QUAN TRỌNG: KHÔNG commit file .env vào Git!
# ============================================================

# --- JIRA Configuration ---

# URL gốc của Jira instance (KHÔNG có dấu / ở cuối)
# Jira Cloud:  https://your-domain.atlassian.net
# Jira Server: https://jira.your-company.com
JIRA_BASE_URL=https://your-domain.atlassian.net

# Email tài khoản Jira (dùng cho Jira Cloud)
JIRA_EMAIL=your-email@company.com

# API Token cho Jira Cloud
# Cách lấy: https://id.atlassian.com/manage-profile/security/api-tokens
# 1. Đăng nhập vào https://id.atlassian.com
# 2. Vào Security → API Tokens → Create API token
# 3. Đặt tên (VD: "Antigravity Automation") → Copy token
JIRA_API_TOKEN=your-jira-api-token-here

# Personal Access Token cho Jira Server / Data Center (thay thế cho Email + API Token)
# Cách lấy: Profile → Personal Access Tokens → Create token
# Nếu dùng PAT thì KHÔNG cần JIRA_EMAIL và JIRA_API_TOKEN
# JIRA_PAT=your-personal-access-token-here

# Jira Project Key mặc định (VD: PROJ, CRM, QA)
JIRA_PROJECT_KEY=PROJ

# --- XRAY Configuration ---

# Platform: 'cloud' hoặc 'server'
XRAY_PLATFORM=cloud

# Xray Cloud - Client ID & Client Secret
# Cách lấy:
# 1. Vào Jira → Apps → Xray → Settings → API Keys
# 2. Hoặc truy cập: https://app.getxray.app → Settings → API Keys
# 3. Tạo API Key mới → Copy Client ID và Client Secret
XRAY_CLIENT_ID=your-xray-client-id
XRAY_CLIENT_SECRET=your-xray-client-secret
