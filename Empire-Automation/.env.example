# =============================================================================
# Empire Automation — Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.
# =============================================================================

# --- Application URL ---
BASE_URL=http://localhost:3000
# Staging: BASE_URL=https://staging.empire.io.vn
# Production: (do not run automation on prod)

# --- Test Credentials ---
TEST_USER_EMAIL=demo@empire.io.vn
TEST_USER_PASSWORD=your_password_here

# --- Admin Credentials (for setup/teardown) ---
ADMIN_EMAIL=admin@empire.io.vn
ADMIN_PASSWORD=your_admin_password_here

# --- CI flag (set to true in CI pipeline) ---
CI=false
