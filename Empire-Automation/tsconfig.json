{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["pages/*"],
      "@fixtures/*": ["tests/fixtures/*"],
      "@utils/*": ["utils/*"],
      "@data/*": ["test_data/*"]
    }
  },
  "include": ["tests/**/*.ts", "pages/**/*.ts", "utils/**/*.ts", "test_data/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules", "dist", "temp", "temp_reports", "reports"]
}
