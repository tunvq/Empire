# Dependencies
node_modules/

# Build output
dist/

# Test artifacts — ignore contents but keep folder structure via .gitkeep
Empire-Automation/temp/*
!Empire-Automation/temp/.gitkeep
Empire-Automation/temp_reports/*
!Empire-Automation/temp_reports/.gitkeep
Empire-Automation/reports/*
!Empire-Automation/reports/.gitkeep
tests/fixtures/.auth/
playwright-report/
test-results/

# Environment — never commit credentials
.env
*.env.local

# Claude Code local settings (machine-specific)
.claude/settings.local.json

# OS
.DS_Store
Thumbs.db
desktop.ini

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
